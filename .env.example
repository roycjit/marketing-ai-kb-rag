# Database
POSTGRES_USER=funnel_rag
POSTGRES_PASSWORD=funnel_rag_local
POSTGRES_DB=funnel_rag
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
DATABASE_URL=postgresql+psycopg2://funnel_rag:funnel_rag_local@localhost:5433/funnel_rag

# Ollama (local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_GENERATION_MODEL=mistral:7b
OLLAMA_CLASSIFICATION_MODEL=llama3.2:3b

# Embeddings (local sentence-transformers)
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIMENSION=384

# Application
LOG_LEVEL=INFO
ENVIRONMENT=development
